{
  "name": "inventory-cf",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src tests eslint.config.js vite.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run --pool=threads --maxWorkers=1",
    "test:e2e": "vitest run tests/e2e.auth.test.ts tests/e2e.public.test.ts tests/e2e.stocktake.test.ts --pool=threads --maxWorkers=1",
    "migrate:verify": "node scripts/migrations.mjs verify",
    "migrate:plan": "node scripts/migrations.mjs plan",
    "migrate:status": "node scripts/migrations.mjs status",
    "migrate:apply": "node scripts/migrations.mjs apply",
    "migrate:bundle": "node scripts/migrations.mjs bundle",
    "perf:explain": "python3 scripts/explain_queries.py",
    "build:functions": "npx --yes wrangler pages functions build functions --outdir .wrangler/pages-functions --project-directory . --build-output-directory dist",
    "test:smoke": "vitest run tests/e2e.public.test.ts tests/e2e.system-ops.smoke.test.ts tests/e2e.backup-drill.smoke.test.ts tests/migrationRegression.test.ts --pool=threads --maxWorkers=1",
    "check:release": "node scripts/release-check.mjs",
    "verify:release": "npm run check:release && npm run check:runtime-sources && npm run check:element-usage && npm run typecheck && npm run build && npm run check:perf-budget && npm run build:functions && npm run test:smoke",
    "check:perf-budget": "node scripts/perf-budget-check.mjs",
    "check:element-usage": "node scripts/check-element-usage.mjs",
    "check:runtime-sources": "node scripts/check-runtime-sources.mjs"
  },
  "dependencies": {
    "element-plus": "^2.7.8",
    "qrcode": "^1.5.4",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.6"
  }
}
